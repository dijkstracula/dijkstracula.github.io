---
layout: base.njk
---

<article class="post">

    <header>
      <div class="post-meta">
        <time datetime="{{ date | isoDate }}">{{ date | isoDate }}</time>
        {% for tag in tags %}{% if tag != "post" %}<span class="sep">·</span><a href="/tags/{{ tag | slugify }}/">#{{ tag }}</a>{% endif %}{% endfor %}
      </div>
      <h1 class="post-title">{{ title }}</h1>
      {% if excerpt %}<p class="post-subtitle">{{ excerpt | safe }}</p>{% endif %}
    </header>

    {% if series %}
    {% set seriesItems = collections.posts | seriesPosts(series) %}
    {% if seriesItems.length > 1 %}
    {%- set currentIdx = 0 -%}
    {%- set total = 0 -%}
    {%- for p in seriesItems -%}
      {%- if not p.data.draft or p.page.url == page.url -%}
        {%- set total = total + 1 -%}
        {%- if p.page.url == page.url -%}{%- set currentIdx = total -%}{%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    <nav class="series-toc" aria-label="Series contents">
      <p class="series-toc-head">
        Part {{ currentIdx }} of {{ total }}{% if seriesMeta[series] and seriesMeta[series].title %} of <em>{{ seriesMeta[series].title }}</em>{% endif %}
      </p>
      <ol>
        {% for p in seriesItems %}
          {% if not p.data.draft or p.page.url == page.url %}
          <li{% if p.page.url == page.url %} class="current"{% endif %}>
            {% if p.page.url == page.url %}
              {{ p.data.series_title or p.data.title }}
            {% else %}
              <a href="{{ p.page.url }}">{{ p.data.series_title or p.data.title }}</a>
            {% endif %}
          </li>
          {% endif %}
        {% endfor %}
      </ol>
    </nav>
    {% endif %}
    {% endif %}

    <div class="prose">
      {{ content | safe }}
    </div>

    {% if series %}
    {% set seriesItems = collections.posts | seriesPosts(series) %}
    {% if seriesItems.length > 1 %}
    {% set prevPost = null %}
    {% set nextPost = null %}
    {% set foundCurrent = false %}
    {% for post in seriesItems %}
      {% if post.page.url == page.url %}
        {% set foundCurrent = true %}
      {% elif not post.data.draft %}
        {% if not foundCurrent %}
          {% set prevPost = post %}
        {% elif not nextPost %}
          {% set nextPost = post %}
        {% endif %}
      {% endif %}
    {% endfor %}
    {% if prevPost or nextPost %}
    <nav class="series-nav" aria-label="Series navigation">
      {% if prevPost %}
      <a href="{{ prevPost.page.url }}" class="prev">
        <span class="label">← Previous</span>
        {{ prevPost.data.series_title or prevPost.data.title }}
      </a>
      {% endif %}
      {% if nextPost %}
      <a href="{{ nextPost.page.url }}" class="next">
        <span class="label">Next →</span>
        {{ nextPost.data.series_title or nextPost.data.title }}
      </a>
      {% endif %}
    </nav>
    {% endif %}
    {% endif %}
    {% endif %}

    <footer class="post-foot">
      <span>Published {{ date | isoDate }}</span>
      <span>
        <a href="/feed.xml">RSS</a> ·
        <a href="mailto:nathan@dijkstracula.net">Reply by email</a>
      </span>
    </footer>

</article>
