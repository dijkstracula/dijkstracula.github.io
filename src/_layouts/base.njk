<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Nathan Taylor</title>

  <!-- Computer Modern body + JetBrains Mono chrome -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/computer-modern@1.0.0/cmun-serif.css" integrity="sha384-RuL10kBzcTDUyCwj1kh9k2FsOnBKUlrJXqUJMfgeSHmomHFI8qsddgkY3NGKS0cX" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono@5/400.css" integrity="sha384-+aDSenDTh79o4iTbyqV1a0t7NimPoIJzYQwPxZf88ryw9Q9RgzJimk6jI+j2DR6q" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono@5/700.css" integrity="sha384-2NiV67JrAv+LWaNRcWDQxPHOnpAE67h3e+J4VvLHzVsFq9NZ3S7q7Y4oSHUd2tTW" crossorigin="anonymous">

  <!-- Syntax highlighting + callouts (still needed) -->
  <link rel="stylesheet" href="/css/syntax.css">

  <!-- Brutalist site styles (loaded last so it wins) -->
  <link rel="stylesheet" href="/css/site.css">

  <link rel="alternate" type="application/atom+xml" title="Nathan Taylor's Blog RSS Feed" href="/feed.xml">

  <script>
    MathJax = {
      tex: {
        inlineMath: [['$', '$']],
        displayMath: [['$$', '$$']],
        processEscapes: true,
        processEnvironments: true
      },
      svg: { linebreaks: { automatic: true } },
      chtml: { linebreaks: { automatic: true } },
      options: { skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'] }
    };
  </script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  <script src="/js/margin-callouts.js"></script>
</head>
<body>

<header class="masthead">
  <h1 class="wordmark"><a href="/">nathan taylor<span class="dot">.</span></a></h1>
</header>

<nav class="primary">
  <a href="/about/"{% if page.url == "/about/" %} class="current"{% endif %}>About</a>
  <a href="/blog/"{% if page.url == "/blog/" %} class="current"{% endif %}>Blog</a>
  <a href="https://github.com/dijkstracula/resume/blob/master/resume.pdf">Resume</a>
  <a href="/blogroll/"{% if page.url == "/blogroll/" %} class="current"{% endif %}>Blogroll</a>
  <a href="/feed.xml">RSS</a>
</nav>

{{ content | safe }}

<footer class="colophon">
  <span>© {{ "" | currentYear }} Nathan Taylor</span>
</footer>

</body>
</html>
