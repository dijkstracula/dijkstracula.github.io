---
layout: base.njk
---

<script>
  // The dither effect is an interactive easter egg; on touch-primary devices
  // (no hover, coarse pointer) it can't be triggered, so skip loading the
  // script entirely — the visible image is already a pre-dithered PNG.
  if (matchMedia("(hover: hover) and (pointer: fine)").matches) {
    const s = document.createElement("script");
    s.src = "/js/dither.js";
    s.defer = true;
    document.head.appendChild(s);
  }
</script>

<main class="home">
  <div class="bio">
    <figure class="card">
      <div class="photo">
        <img src="/assets/me-dithered.png" alt="Nathan Taylor"
             class="dither" data-dither-scale="2"
             data-dither-interactive data-dither-source="/assets/me.jpg">
      </div>
    </figure>
    <div class="prose">
      {{ content | safe }}
      <a class="more" href="/about/">More about me →</a>
    </div>
  </div>

  <section class="log">
    <h3>Recent posts</h3>
    <ol class="entries">
      {% for post in collections.publishedPosts | limit(5) %}
      <li>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
        <span class="date">{{ post.date | readableDate }}</span>
        {% if post.data.excerpt %}<span class="sub">{{ post.data.excerpt }}</span>{% endif %}
      </li>
      {% endfor %}
    </ol>
    <p class="log-foot">
      <a href="/blog/">All posts</a> ·
      <a href="/tags/">By tag</a> ·
      <a href="/feed.xml">RSS</a>
    </p>
  </section>
</main>
