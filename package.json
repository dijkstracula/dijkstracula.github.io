{
  "name": "blog",
  "version": "1.0.0",
  "description": "A minimal modern blog built with 11ty, HTMX, and Pico.css",
  "scripts": {
    "start": "eleventy --serve",
    "build": "node scripts/fetch-feeds.js && eleventy",
    "fetch-feeds": "node scripts/fetch-feeds.js",
    "dither:headshot": "node scripts/dither-asset.js src/assets/me.jpg src/assets/me-dithered.png 2",
    "fonts:subset": "node scripts/subset-math.js"
  },
  "keywords": [
    "blog",
    "11ty",
    "htmx",
    "pico"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "markdown-it-footnote": "^4.0.0",
    "sharp": "^0.34.5",
    "subset-font": "^2.5.0",
    "terser": "^5.47.1"
  },
  "dependencies": {
    "@11ty/eleventy-fetch": "^5.1.1",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "markdown-it-container": "^4.0.0",
    "rss-parser": "^3.13.0"
  }
}
